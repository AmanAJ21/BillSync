{
    "framework": "nextjs",
    "buildCommand": "next build",
    "outputDirectory": ".next",
    "installCommand": "npm install",
    "crons": [
        {
            "path": "/api/cron",
            "schedule": "0 0 * * *"
        }
    ],
    "regions": [
        "bom1"
    ],
    "env": {
        "NODE_ENV": "production"
    },
    "headers": [
        {
            "source": "/api/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-store, max-age=0"
                }
            ]
        }
    ]
}